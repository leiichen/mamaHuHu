# 生产环境配置（复制为 .env.production，部署前必填）
# cp .env.production.example .env.production

PORT=16668

# MySQL 数据库连接
DATABASE_URL="mysql://user:password@localhost:3306/xiaomaque"

# JWT 密钥
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRES_IN=7d

# OpenAI API（LangChain 使用）
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1

# 允许跨域的前端地址，多个用英文逗号分隔
CORS_ORIGIN=https://your-frontend-domain.com

# API 请求签名密钥（需与前端 VITE_API_SIGN_SECRET 保持一致）
API_SIGN_SECRET=your-api-sign-secret

# 虎牙 art 平台（图片/视频生成）
HUYA_ART_API_KEY=your-huya-art-api-key
HUYA_ART_BASE_URL=https://art.huya.info/openapi/v1
HUYA_ART_PROVIDER=volcengine
SEEDREAM_MODEL=doubao-seedream-4-5-251128
SEEDANCE_MODEL=seedance-2.0-cn

# 七牛云对象存储（QINIU_CDN_BASE_URL 为必填项）
QINIU_ACCESS_KEY=your-qiniu-access-key
QINIU_SECRET_KEY=your-qiniu-secret-key
QINIU_BUCKET=your-qiniu-bucket
QINIU_CDN_BASE_URL=https://your-cdn-domain.com
